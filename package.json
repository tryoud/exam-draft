{
  "name": "examdraft",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "check": "astro check",
    "typecheck": "astro check",
    "preview": "astro preview",
    "pages:dev": "wrangler pages dev dist --compatibility-date=2026-04-28",
    "db:migrate:local": "wrangler d1 migrations apply examdraft --local",
    "db:migrate:remote": "wrangler d1 migrations apply examdraft --remote",
    "deploy": "npm run build && wrangler pages deploy dist --project-name=examdraft",
    "verify:functions": "find functions -name '*.js' -print0 | xargs -0 -n1 node --check",
    "verify": "npm run verify:functions && npm run check && npm run build"
  },
  "dependencies": {
    "@astrojs/react": "^5.0.4",
    "astro": "^6.1.9",
    "pdfjs-dist": "^5.7.284",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.7.2"
  }
}
