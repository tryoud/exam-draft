---
import '../../styles/global.css';

const benefits = [
  { value: '1', label: 'Exam structure', copy: 'Past exams become a believable format with recognizable structure.' },
  { value: '2', label: 'Study paths', copy: 'Generate a full mock exam or isolate one task type for focused practice.' },
  { value: '3', label: 'Feedback loop', copy: 'Write answers, get corrections, and turn the result into the next study step.' },
  { value: '4', label: 'Data control', copy: 'No ExamDraft backend for your content, only your own API key.' },
];

const metrics = [
  { value: '100K+', label: 'possible combinations of topics, difficulty and task types' },
  { value: '~€0.20', label: 'typical total cost per run' },
  { value: '30+', label: 'minutes of prep work saved per study session' },
  { value: '97%', label: 'more calm when the exam format already feels familiar' },
];

const cards = [
  {
    title: 'Learn the shape, not just the subject',
    body: 'ExamDraft reconstructs structure, point distribution and tone from the originals. That is exactly what generic study tools usually miss.',
  },
  {
    title: 'Practice difficult task types in isolation',
    body: 'If one recurring task type keeps causing trouble, generate multiple variations of it instead of another full exam.',
  },
  {
    title: 'Stay inside one focused interface',
    body: 'Writing, grading and exporting happen in one connected study flow instead of being spread across several tools.',
  },
  {
    title: 'Choose the model for your material',
    body: 'Use OpenRouter for flexibility or Anthropic directly for image-heavy PDFs. Your own API key controls cost and quality.',
  },
];
---

<!doctype html>
<html lang="en" class="landing-html">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="ExamDraft turns past exams into believable mock exams with solutions, corrections, and export."
    />
    <title>ExamDraft — Behind every question, a pattern</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  </head>
  <body class="landing-body landing-grid overflow-x-hidden">
    <div class="editorial-shell">
      <nav class="top-nav fixed inset-x-0 top-0 z-50">
        <div class="mx-auto flex max-w-6xl items-center justify-between px-5 py-4 sm:px-6">
          <div class="flex items-center gap-3 scroll-fade-right" data-reveal>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32" class="h-9 w-9 shrink-0">
              <rect width="32" height="32" rx="7" fill="#111111"/>
              <rect x="8" y="8"    width="16" height="3.5" rx="1.75" fill="#f0ebe2"/>
              <rect x="8" y="14.25" width="11" height="3.5" rx="1.75" fill="#f0ebe2"/>
              <rect x="8" y="20.5" width="16" height="3.5" rx="1.75" fill="#f0ebe2"/>
            </svg>
            <div>
              <p class="text-sm font-semibold tracking-tight text-[#111318]">ExamDraft</p>
              <p class="hidden sm:block text-[11px] uppercase tracking-[0.18em] text-[#707070]">exam design for practice</p>
            </div>
          </div>

          <div class="hidden items-center gap-8 text-sm text-[#6c6c6c] md:flex">
            <a href="#benefits" class="transition-colors hover:text-[#111111]">Benefits</a>
            <a href="#metrics" class="transition-colors hover:text-[#111111]">Metrics</a>
            <a href="#final" class="transition-colors hover:text-[#111111]">Start</a>
          </div>

          <div class="flex items-center gap-3">
            <a href="/" class="secondary-link px-4 py-2 text-xs">DE</a>
            <span class="study-accent rounded-full px-3 py-2 text-xs font-semibold">EN</span>
            <a href="/app" class="primary-link scroll-reveal px-5 py-3 text-sm" data-reveal style="--reveal-delay:120ms">
              Open app
              <span aria-hidden="true">→</span>
            </a>
          </div>
        </div>
      </nav>

      <main>
        <section class="px-5 pb-20 pt-28 sm:px-6 sm:pt-36">
          <div class="mx-auto grid max-w-6xl gap-10 lg:grid-cols-[minmax(0,1.05fr)_minmax(0,0.95fr)] lg:items-start">
            <div class="min-w-0 space-y-8">
              <div class="space-y-4">
                <div class="scroll-reveal" data-reveal>
                  <p class="text-[11px] uppercase tracking-[0.22em] text-[#7b7b7b]">exam preparation / deliberately designed</p>
                </div>

                <div class="space-y-6">
                  <h1 class="display-title scroll-reveal text-[3.8rem] leading-[0.9] sm:text-[5.8rem] lg:text-[7rem]" data-reveal style="--reveal-delay:80ms">
                    BEHIND EVERY
                    <br />
                    QUESTION
                    <span class="mt-[0.12em] block text-[0.58em] leading-[0.95] tracking-[-0.03em]">
                      — A PATTERN.
                    </span>
                  </h1>

                  <p class="scroll-reveal max-w-xl text-lg leading-8 muted-copy sm:text-xl" data-reveal style="--reveal-delay:180ms">
                    ExamDraft is not about memorizing one past exam. It is about understanding
                    how exams in this subject are constructed: recurring task types, patterns,
                    weightings, and the kinds of reasoning they expect.
                  </p>
                </div>
              </div>
            </div>

            <div class="hero-devices min-w-0 lg:w-[305px] xl:w-[360px] lg:ml-auto">
              <div class="hero-phone hero-phone-front scroll-reveal parallax-float" data-reveal data-parallax="0.18">
                <div class="phone-shell aspect-[0.49] p-3">
                  <div class="phone-screen h-full rounded-[1.55rem] bg-[#f6f2ea] p-4">
                    <div class="mt-5 flex items-center justify-between text-[10px] uppercase tracking-[0.2em] text-[#888]">
                      <span>Progress</span>
                      <span>+12%</span>
                    </div>
                    <div class="phone-card mt-6 rounded-[1.2rem] border border-black/8 bg-white/70 p-3">
                      <div class="mb-3 h-2 w-16 rounded-full bg-black/8"></div>
                      <svg viewBox="0 0 220 140" class="w-full">
                        <path class="chart-line-muted" d="M0 110 C30 80 55 85 82 66 C106 48 126 46 150 56 C176 68 193 44 220 24" />
                        <path class="chart-line" d="M0 116 C24 104 52 70 80 76 C101 80 128 32 154 42 C182 54 196 44 220 18" />
                      </svg>
                    </div>
                    <div class="mt-4 grid grid-cols-2 gap-3 text-[11px]">
                      <div class="phone-card min-w-0 rounded-2xl border border-black/6 bg-white/70 p-3">
                        <p class="text-[10px] leading-tight text-[#999]">Topics</p>
                        <p class="mt-2 text-lg font-semibold text-[#111]">12</p>
                      </div>
                      <div class="phone-card min-w-0 rounded-2xl bg-[#6b8dff] p-3 text-white">
                        <p class="text-[10px] leading-tight text-white/75">Confidence</p>
                        <p class="mt-2 text-lg font-semibold">93%</p>
                      </div>
                    </div>
                  </div>
                </div>
              </div>

              <div class="hero-phone hero-phone-back scroll-reveal parallax-float" data-reveal data-parallax="-0.12" style="--reveal-delay:140ms">
                <div class="phone-shell aspect-[0.49] p-3">
                  <div class="phone-screen phone-screen-stack grid-dots h-full rounded-[1.55rem] bg-[#f6f2ea] p-4">
                    <div class="mt-5 flex items-center justify-between text-[10px] uppercase tracking-[0.2em] text-[#888]">
                      <span>Exam mode</span>
                      <span>90m</span>
                    </div>
                    <div class="phone-card phone-card-grow rounded-[1.3rem] border border-black/6 bg-white/70 p-4">
                      <p class="text-[11px] uppercase tracking-[0.16em] text-[#999]">Question 01</p>
                      <p class="mt-3 text-[0.96rem] leading-[1.5] text-[#333]">
                        Reconstruct the frequency response and justify the filter choice based on
                        the given constraints.
                      </p>
                    </div>
                    <div class="phone-card phone-card-compact rounded-[1.3rem] border border-[#6b8dff]/25 bg-[#eef1ff] p-4 text-[#3a5fd4]">
                      <p class="text-[11px] uppercase tracking-[0.16em]">Revision mode</p>
                      <p class="mt-2 text-[0.96rem] leading-[1.5]">
                        Same task type, new values, new scenario.
                      </p>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </section>

        <section id="benefits" class="anchor-offset px-5 py-10 sm:px-6">
          <div class="mx-auto max-w-6xl">
            <div class="landing-card-strong rounded-[2rem] px-6 py-7 sm:px-8">
              <div class="scroll-reveal flex flex-col gap-8 lg:flex-row lg:items-end lg:justify-between" data-reveal>
                <div>
                  <p class="editorial-kicker">Learning the format</p>
                  <h2 class="section-title mt-4 text-4xl sm:text-5xl">Do not learn one past exam. Learn how this subject builds its exams.</h2>
                </div>
                <p class="max-w-xl text-base leading-8 muted-copy">
                  Repeating the same past exam five times can create a strong illusion of mastery,
                  even when you only know that one paper extremely well. ExamDraft counters that
                  bias by extracting the structure behind multiple real exams and generating new,
                  fitting practice from it.
                </p>
              </div>
            </div>

            <div class="mt-6 grid gap-4 md:grid-cols-2 xl:grid-cols-4">
              {benefits.map((benefit, index) => (
                <article class="scroll-reveal landing-card rounded-[1.8rem] p-6" data-reveal style={`--reveal-delay:${index * 90}ms`}>
                  <p class="text-[4.25rem] font-extrabold leading-none tracking-[-0.08em] text-[#111111]">{benefit.value}</p>
                  <h3 class="mt-4 text-sm font-semibold uppercase tracking-[0.14em] text-[#111111]">{benefit.label}</h3>
                  <p class="mt-3 text-sm leading-7 text-[#4c4c4c]">{benefit.copy}</p>
                </article>
              ))}
            </div>
          </div>
        </section>

        <section id="metrics" class="anchor-offset px-5 py-24 sm:px-6">
          <div class="mx-auto max-w-6xl">
            <div class="scroll-reveal mb-12 max-w-2xl" data-reveal>
              <p class="editorial-kicker">Study signals</p>
              <h2 class="section-title mt-4 text-4xl sm:text-5xl">Metrics that make preparation tangible.</h2>
            </div>

            <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
              {metrics.map((metric, index) => (
                <article class="scroll-reveal rounded-[1.8rem] border border-black/8 bg-white px-6 py-7" data-reveal style={`--reveal-delay:${index * 110}ms`}>
                  <p class="text-[2.35rem] font-extrabold tracking-[-0.08em] text-[#111111]">{metric.value}</p>
                  <p class="mt-3 text-sm leading-7 text-[#4d4d4d]">{metric.label}</p>
                </article>
              ))}
            </div>
          </div>
        </section>

        <section class="px-5 py-24 sm:px-6">
          <div class="mx-auto max-w-6xl">
            <div class="scroll-reveal learning-panel overflow-hidden rounded-[2rem] p-4 sm:p-6" data-reveal>
              <div class="rounded-[1.6rem] border border-black/8 bg-[#f6f2ea] p-5 sm:p-8">
                <div class="flex flex-col gap-8 lg:flex-row lg:items-end lg:justify-between">
                  <div>
                    <p class="text-[11px] uppercase tracking-[0.18em] text-[#7a7688]">Study progress</p>
                    <h2 class="mt-4 max-w-2xl text-4xl font-extrabold leading-[0.9] tracking-[-0.08em] text-[#111111] sm:text-6xl">
                      LESS
                      <br />
                      GUESSWORK.
                      <br />
                      MORE ROUTINE.
                    </h2>
                  </div>
                  <div class="max-w-md">
                    <p class="text-base leading-8 text-[#55515f]">
                      Do not memorize one paper.
                      Learn how this subject usually turns knowledge into exam questions.
                    </p>
                  </div>
                </div>

                <div class="mt-8 grid gap-4 lg:grid-cols-[1.2fr_0.8fr]">
                  <div class="grid gap-3">
                    <article class="learning-step rounded-[1.45rem] px-5 py-5">
                      <div class="flex items-start gap-4">
                        <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-2xl bg-[#111113] text-sm font-extrabold text-white">01</div>
                        <div>
                          <p class="text-[11px] uppercase tracking-[0.18em] text-[#7a7688]">Analysis</p>
                          <h3 class="mt-2 text-xl font-semibold tracking-[-0.03em] text-[#111111]">You identify the pattern.</h3>
                          <p class="mt-3 max-w-xl text-sm leading-7 text-[#55515f]">
                            Which task types and operators return again and again?
                          </p>
                        </div>
                      </div>
                    </article>

                    <article class="learning-step rounded-[1.45rem] px-5 py-5">
                      <div class="flex items-start gap-4">
                        <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-2xl bg-[#6b8dff] text-sm font-extrabold text-white">02</div>
                        <div>
                          <p class="text-[11px] uppercase tracking-[0.18em] text-[#7a7688]">Practice</p>
                          <h3 class="mt-2 text-xl font-semibold tracking-[-0.03em] text-[#111111]">You train new variations.</h3>
                          <p class="mt-3 max-w-xl text-sm leading-7 text-[#55515f]">
                            Same structure, new content. That is how real routine forms.
                          </p>
                        </div>
                      </div>
                    </article>

                    <article class="learning-step rounded-[1.45rem] px-5 py-5">
                      <div class="flex items-start gap-4">
                        <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-2xl bg-[#c4573a] text-sm font-extrabold text-white">03</div>
                        <div>
                          <p class="text-[11px] uppercase tracking-[0.18em] text-[#7a7688]">Grading</p>
                          <h3 class="mt-2 text-xl font-semibold tracking-[-0.03em] text-[#111111]">You sharpen the weak spots.</h3>
                          <p class="mt-3 max-w-xl text-sm leading-7 text-[#55515f]">
                            Feedback shows what already works and what still needs one more round.
                          </p>
                        </div>
                      </div>
                    </article>
                  </div>

                  <aside class="study-composition px-2 py-2 lg:px-0">
                    <div class="study-sheet study-sheet-main">
                      <div class="flex items-center justify-between text-[10px] uppercase tracking-[0.18em] text-[#7a7688]">
                        <span>ExamDraft</span>
                        <span>Analysis</span>
                      </div>
                      <h3 class="mt-5 text-2xl font-semibold tracking-[-0.04em] text-[#111111]">Signals</h3>
                      <p class="mt-1 text-sm text-[#6a6576]">Recurring structure reconstructed from several past exams</p>
                      <div class="mt-5 space-y-3">
                        <div class="study-line-item">
                          <span class="study-line-label">reconstruction</span>
                          <span class="study-line-track"><span style="width: 82%"></span></span>
                        </div>
                        <div class="study-line-item">
                          <span class="study-line-label">justification</span>
                          <span class="study-line-track"><span style="width: 68%"></span></span>
                        </div>
                        <div class="study-line-item">
                          <span class="study-line-label">filter choice</span>
                          <span class="study-line-track"><span style="width: 61%"></span></span>
                        </div>
                      </div>
                      <div class="mt-6 rounded-[1.1rem] bg-[#f4f1ea] p-4">
                        <p class="text-[10px] uppercase tracking-[0.18em] text-[#8d8797]">Note</p>
                        <p class="mt-2 text-sm leading-6 text-[#45414d]">
                          New tasks should test the same reasoning, not simply repeat the same numbers.
                        </p>
                      </div>
                    </div>

                    <div class="study-sheet study-sheet-side">
                      <p class="text-[10px] uppercase tracking-[0.18em] text-[#7a7688]">Exam feel</p>
                      <div class="mt-4 space-y-4">
                        <div>
                          <div class="mb-2 flex items-center justify-between text-[10px] uppercase tracking-[0.16em] text-[#7a7688]">
                            <span>Format familiarity</span>
                            <span>rises</span>
                          </div>
                          <div class="learning-meter grid grid-cols-4 gap-2">
                            <span class="h-2.5 rounded-full bg-[#d9e3ff]"></span>
                            <span class="h-2.5 rounded-full bg-[#b2c7ff]"></span>
                            <span class="h-2.5 rounded-full bg-[#8eaaff]"></span>
                            <span class="h-2.5 rounded-full bg-[#6b8dff]"></span>
                          </div>
                        </div>
                        <div>
                          <div class="mb-2 flex items-center justify-between text-[10px] uppercase tracking-[0.16em] text-[#7a7688]">
                            <span>Uncertainty</span>
                            <span>falls</span>
                          </div>
                          <div class="learning-meter grid grid-cols-4 gap-2">
                            <span class="h-2.5 rounded-full bg-[#d98267]"></span>
                            <span class="h-2.5 rounded-full bg-[#e6b6aa]"></span>
                            <span class="h-2.5 rounded-full bg-[#f0d9d2]"></span>
                            <span class="h-2.5 rounded-full bg-[#f6efeb]"></span>
                          </div>
                        </div>
                      </div>
                    </div>
                  </aside>
                </div>
              </div>
            </div>
          </div>
        </section>

        <section class="px-5 py-24 sm:px-6">
          <div class="mx-auto max-w-6xl">
            <div class="grid gap-4 lg:grid-cols-[0.88fr_1.12fr]">
              <div class="scroll-reveal paper-panel rounded-[2rem] p-6 sm:p-8" data-reveal>
                <div class="pl-7">
                  <p class="red-note text-xs uppercase">Exam confidence</p>
                  <h2 class="section-title mt-4 text-4xl sm:text-5xl">Become less surprised by the real exam.</h2>
                  <p class="mt-6 max-w-md text-base leading-8 text-[#4e4e4e]">
                    If you understand the exam format, preparation becomes calmer. ExamDraft turns
                    several past exams into practice that stays closer to the real thing than
                    simply repeating the same known questions again and again.
                  </p>
                </div>
              </div>

              <div class="grid gap-4 md:grid-cols-2">
                {cards.map((card, index) => (
                  <article class="scroll-reveal landing-card rounded-[1.8rem] p-7" data-reveal style={`--reveal-delay:${index * 90}ms`}>
                    <h3 class="text-2xl font-extrabold leading-[0.95] tracking-[-0.03em] text-[#111111]">{card.title}</h3>
                    <p class="mt-5 text-base leading-8 text-[#4b4b4b]">{card.body}</p>
                  </article>
                ))}
              </div>
            </div>
          </div>
        </section>

        <section id="final" class="anchor-offset px-5 pb-24 pt-12 sm:px-6">
          <div class="mx-auto max-w-6xl">
            <div class="scroll-reveal lime-panel rounded-[2rem] px-6 py-10 sm:px-10 sm:py-14" data-reveal>
              <div class="flex flex-col gap-8 lg:flex-row lg:items-end lg:justify-between">
                <div class="max-w-3xl min-w-0">
                  <p class="text-[11px] uppercase tracking-[0.2em] text-black/55">ExamDraft</p>
                  <h2 class="mt-5 max-w-[13ch] text-[3rem] font-extrabold leading-[0.86] tracking-[-0.04em] text-black sm:text-[4.8rem] lg:text-[5.6rem]">
                    LEARN THE FORMAT.
                    <br />
                    NOT JUST THE ANSWERS.
                  </h2>
                </div>

                <div class="flex shrink-0 flex-col gap-3 sm:flex-row lg:flex-col">
                  <a href="/app" class="secondary-link border-black/15 bg-black text-white hover:bg-[#1a1a1a] hover:text-white">
                    Open app
                    <span aria-hidden="true">→</span>
                  </a>
                </div>
              </div>
            </div>
          </div>
        </section>
      </main>

      <footer class="px-5 pb-10 sm:px-6">
        <div class="mx-auto flex max-w-6xl flex-col gap-5 border-t border-black/8 pt-6 text-sm sm:flex-row sm:items-end sm:justify-between">
          <div>
            <p class="font-semibold tracking-tight text-[#111111]">ExamDraft</p>
            <p class="mt-1 text-[#6f6f6f]">Mock exams built from real past exams.</p>
            <p class="footer-note mt-2 max-w-md">
              Built for exam prep that focuses on understanding patterns, task types, and
              weighting instead of memorizing one past paper.
            </p>
          </div>
          <div class="flex flex-wrap gap-5">
            <a href="/app" class="footer-link">App</a>
            <a href="/en/terms" class="footer-link">Terms</a>
            <a href="/en/privacy" class="footer-link">Privacy</a>
          </div>
        </div>
      </footer>
    </div>

    <script>
      const items = document.querySelectorAll('[data-reveal]');
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.18, rootMargin: '0px 0px -8% 0px' });

      items.forEach((item) => observer.observe(item));

      const parallaxNodes = Array.from(document.querySelectorAll('[data-parallax]'));
      const updateParallax = () => {
        const viewport = window.innerHeight;
        parallaxNodes.forEach((node) => {
          const rect = node.getBoundingClientRect();
          const speed = Number(node.getAttribute('data-parallax')) || 0;
          const progress = (rect.top + rect.height / 2 - viewport / 2) * speed;
          node.style.setProperty('--parallax-shift', `${progress}px`);
        });
      };

      updateParallax();
      window.addEventListener('scroll', updateParallax, { passive: true });
      window.addEventListener('resize', updateParallax);
    </script>
  </body>
</html>
