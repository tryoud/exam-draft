---
import '../../styles/global.css';
import CloudflareAnalytics from '../../components/CloudflareAnalytics.astro';
import PartnerApply from '../../components/PartnerApply';
---

<!doctype html>
<html lang="en" class="legal-html">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="ExamDraft Partner Pilot: Free access for student unions, tutoring groups and university organisations. Private module pool, no original publishing."
    />
    <title>Partner Pilot — ExamDraft</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <CloudflareAnalytics />
  </head>
  <body class="legal-body overflow-x-hidden">
    <div class="legal-shell">
      <header class="legal-topbar sticky top-0 z-50">
        <div class="mx-auto flex max-w-5xl items-center justify-between px-5 py-4 sm:px-6">
          <a href="/en" class="flex items-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32" class="h-9 w-9 shrink-0">
              <rect width="32" height="32" rx="7" fill="#111111"/>
              <rect x="8" y="8" width="16" height="3.5" rx="1.75" fill="#f0ebe2"/>
              <rect x="8" y="14.25" width="11" height="3.5" rx="1.75" fill="#f0ebe2"/>
              <rect x="8" y="20.5" width="16" height="3.5" rx="1.75" fill="#f0ebe2"/>
            </svg>
            <div>
              <p class="text-sm font-semibold tracking-tight text-[#111318]">ExamDraft</p>
              <p class="text-[11px] uppercase tracking-[0.18em] text-[#707070]">For student unions</p>
            </div>
          </a>
          <div class="flex items-center gap-3">
            <a href="/partner" class="secondary-link px-4 py-2 text-xs">DE</a>
            <span class="study-accent rounded-full px-3 py-2 text-xs font-semibold">EN</span>
          </div>
        </div>
      </header>

      <main class="px-5 pb-20 pt-14 sm:px-6 sm:pt-16">
        <div class="mx-auto max-w-5xl space-y-10">

          <section class="legal-hero rounded-[2rem] px-6 py-8 sm:px-8 sm:py-10">
            <p class="legal-kicker">Partner Pilot</p>
            <h1 class="legal-section-title mt-4 text-4xl sm:text-5xl">Exam intelligence for your students.</h1>
            <p class="legal-copy mt-6 max-w-3xl text-base sm:text-lg">
              You keep control of your past exam archive. ExamDraft does not publish original exams.
              We turn them into private analysis, practice exams, and study paths for your students —
              fully under your control.
            </p>
            <div class="mt-6 flex flex-wrap gap-3">
              <span class="legal-meta-chip">Free pilot</span>
              <span class="legal-meta-chip">No original publishing</span>
              <span class="legal-meta-chip">Private module pools</span>
            </div>
          </section>

          <section class="grid gap-4 md:grid-cols-3">
            {[
              {
                icon: '🔒',
                title: 'Originals stay private',
                body: 'ExamDraft does not store original PDFs for other users. Your exams become a pattern database — not a download archive.',
              },
              {
                icon: '📊',
                title: '100 free analysis credits',
                body: 'Partner organisations receive 100 credits to start — for analyses, practice exams, and type training. Your students also get a 20% discount code.',
              },
              {
                icon: '🎓',
                title: 'Anonymised insights',
                body: 'After each exam period you receive aggregated data: which task types appear how often, which topics matter — without individual user data.',
              },
            ].map((card) => (
              <article class="legal-card rounded-[1.7rem] p-6">
                <div class="text-3xl mb-3">{card.icon}</div>
                <h3 class="text-base font-semibold text-[#111111]">{card.title}</h3>
                <p class="mt-2 text-sm text-[#6f6a78] leading-6">{card.body}</p>
              </article>
            ))}
          </section>

          <section class="legal-card rounded-[1.9rem] p-6 sm:p-8">
            <p class="legal-kicker">What is included in the pilot</p>
            <div class="mt-6 grid gap-3 sm:grid-cols-2">
              {[
                'Private module pool for your organisation',
                '100 free analysis credits to start',
                '20% discount code for your students',
                'No publishing of your original PDFs',
                'Anonymised insights after the exam period',
                'Feedback call to shape further development',
              ].map((item) => (
                <div class="flex items-start gap-2.5">
                  <span class="mt-0.5 shrink-0 text-[#2e7d4f] font-bold text-sm">✓</span>
                  <p class="text-sm text-[#4c4754]">{item}</p>
                </div>
              ))}
            </div>
          </section>

          <section class="legal-card rounded-[1.9rem] p-6 sm:p-8">
            <p class="legal-kicker">What ExamDraft does not build</p>
            <div class="legal-copy mt-4 space-y-2 text-sm text-[#6f6a78]">
              <p>No public past exam search. No download archive of other people's exams. No unreviewed sharing of original PDFs. ExamDraft learns patterns — no originals are stored or shared.</p>
            </div>
          </section>

          <section>
            <h2 class="text-2xl font-semibold text-[#111111] mb-6">Apply for the pilot</h2>
            <PartnerApply lang="en" client:load />
            <p class="mt-4 text-xs text-[#9e98a4] text-center">
              Questions? Write to us directly at
              <a href="mailto:partner@examdraft.com" class="underline ml-1">partner@examdraft.com</a>
            </p>
          </section>

        </div>
      </main>
    </div>
  </body>
</html>
