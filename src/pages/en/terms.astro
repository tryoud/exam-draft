---
import '../../styles/global.css';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Terms of Use — ExamDraft</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <header class="sticky top-0 h-14 bg-[#0a0a0a] border-b border-[#222222] flex items-center justify-between px-4">
      <a href="/en" class="text-white font-bold text-lg hover:text-blue-400 transition-colors">
        ExamDraft
      </a>
      <div class="flex items-center gap-3 text-xs">
        <a href="/terms" class="text-gray-500 hover:text-gray-300 transition-colors">DE</a>
        <span class="text-white">EN</span>
      </div>
    </header>
    <main class="max-w-2xl mx-auto px-4 py-12">
      <h1 class="text-2xl font-bold text-white mb-6">Terms of Use</h1>

      <div class="space-y-6 text-gray-400 text-sm leading-relaxed">
        <p>
          These terms govern the use of ExamDraft. By using the service, you agree to these terms.
        </p>

        <section>
          <h2 class="text-white font-semibold mb-2">1. Use of the service</h2>
          <p>
            ExamDraft is an AI-assisted tool for generating practice exams. The service may only
            be used for lawful and personal study purposes.
          </p>
        </section>

        <section>
          <h2 class="text-white font-semibold mb-2">2. Copyright</h2>
          <p>
            You may only upload documents for which you own the copyright or have explicit
            permission from the rights holder. ExamDraft accepts no liability for copyright
            violations caused by users.
          </p>
        </section>

        <section>
          <h2 class="text-white font-semibold mb-2">3. API usage (BYOK)</h2>
          <p>
            ExamDraft uses a Bring Your Own Key model. You use your own provider key and bear all
            related API costs. ExamDraft does not provide its own API resources.
          </p>
        </section>

        <section>
          <h2 class="text-white font-semibold mb-2">4. Disclaimer</h2>
          <p>
            ExamDraft is provided as is. We do not guarantee the correctness or completeness of
            generated content. Generated exams are intended for practice only.
          </p>
        </section>

        <section>
          <h2 class="text-white font-semibold mb-2">5. Contact</h2>
          <p>
            Questions: <a href="mailto:legal@examdraft.com" class="text-blue-400 hover:text-blue-300">legal@examdraft.com</a>
          </p>
        </section>

        <p class="text-gray-600 text-xs">Version: March 2026</p>
      </div>
    </main>
  </body>
</html>
