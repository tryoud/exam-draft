---
import '../styles/global.css';
import ExamDraftApp from '../components/App';
import CloudflareAnalytics from '../components/CloudflareAnalytics.astro';
---

<!doctype html>
<html lang="de" class="app-html">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="ExamDraft — KI-gestützter Klausurgenerator. Lade Altklausuren hoch und generiere neue Probeklausuren mit Musterlösungen." />
    <title>ExamDraft — App</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <script is:inline>
      const params = new URLSearchParams(window.location.search);
      if (params.get('lang') === 'de') {
        localStorage.setItem('examdraft_locale', 'de');
      } else if (params.get('lang') === 'en') {
        localStorage.setItem('examdraft_locale', 'en');
        params.delete('lang');
        const query = params.toString();
        window.location.replace(`/en/app${query ? `?${query}` : ''}${window.location.hash}`);
      } else if (localStorage.getItem('examdraft_locale') === 'en') {
        window.location.replace(`/en/app${window.location.search}${window.location.hash}`);
      }
    </script>
    <CloudflareAnalytics />
  </head>
  <body class="app-body">
    <ExamDraftApp client:load />
  </body>
</html>
